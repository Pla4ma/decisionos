# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# RevenueCat (for monetization)
EXPO_PUBLIC_REVENUECAT_API_KEY=your_revenuecat_api_key

# Expo Project ID (required for push notifications)
EXPO_PUBLIC_PROJECT_ID=your_expo_project_id

# Environment
EXPO_PUBLIC_ENVIRONMENT=development

# ──────────────────────────────────────────────
# GEMINI AI KEY — DO NOT set as EXPO_PUBLIC
# The Gemini API key is configured server-side in:
#   supabase/functions/analyze-decision/index.ts
# via the SUPABASE_SERVICE_ROLE_KEY env var set
# in the Supabase dashboard (not in this file).
# Exposing it via EXPO_PUBLIC would leak your key
# to every app user.
# ──────────────────────────────────────────────
